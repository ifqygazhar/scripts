#!/bin/bash

# Stop the script if any command fails
set -e

echo "=================================================="
echo "  Starting Docker & dockur/windows Installation   "
echo "=================================================="

# --- Version Selection ---
echo "Available Windows Versions:"
echo "  11   - Windows 11 Pro (7.9 GB)"
echo "  11l  - Windows 11 LTSC (4.7 GB)"
echo "  10   - Windows 10 Pro (5.7 GB)"
echo "  10l  - Windows 10 LTSC (4.6 GB)"
echo "  8e   - Windows 8.1 Enterprise (3.7 GB)"
echo "  7u   - Windows 7 Ultimate (3.1 GB)"
echo "  xp   - Windows XP Professional (0.6 GB)"
echo "  2025 - Windows Server 2025 (7.6 GB)"
echo "  2022 - Windows Server 2022 (6.0 GB)"
echo "  2019 - Windows Server 2019 (5.3 GB)"
echo "--------------------------------------------------"
read -p "Enter the version code you want to install (Default is 11): " WIN_VERSION

# Set default to 11 if the user leaves it blank
WIN_VERSION=${WIN_VERSION:-11}
echo "Selected Version: $WIN_VERSION"

# --- Storage Selection ---
echo "--------------------------------------------------"
echo "Disk Size Allocation"
echo "Example: 50G, 200G, 250G"
echo "Warning: Do not allocate 100% of your VPS storage. Leave space for Ubuntu!"
read -p "Enter the disk size you want to allocate (Default is 64G): " DISK_SIZE

# Set default to 64G if the user leaves it blank
DISK_SIZE=${DISK_SIZE:-64G}
echo "Selected Disk Size: $DISK_SIZE"
echo "=================================================="

# 1. Update & Upgrade System Packages
echo "--> Updating system package list..."
sudo apt update && sudo apt upgrade -y

# 2. Install Basic Dependencies
echo "--> Installing Git, Curl, and CPU Checker..."
sudo apt install -y git curl cpu-checker

# 3. Check KVM Validation (Crucial for Windows Performance)
echo "--> Checking KVM Virtualization status..."
if [ -e /dev/kvm ]; then
    echo "[OK] /dev/kvm found. KVM acceleration is active."
else
    echo "[WARNING] /dev/kvm NOT found!"
    echo "Windows might run very slowly or fail to boot."
    echo "Please ensure your VPS supports KVM / Nested Virtualization."
    read -p "Do you still want to continue? (y/n): " temp_choice
    if [ "$temp_choice" != "y" ]; then
        echo "Installation aborted."
        exit 1
    fi
fi

# 4. Install Docker Using the Official Script
echo "--> Downloading and installing the latest version of Docker..."
curl -fsSL https://get.docker.com -o get-docker.sh
sudo sh get-docker.sh
rm get-docker.sh

# 5. Ensure Docker Service is Running
echo "--> Enabling and starting Docker service..."
sudo systemctl enable --now docker

# 6. Clone the dockur/windows Repository
echo "--> Cloning dockur/windows repository..."
if [ -d "windows" ]; then
    echo "The 'windows' directory already exists. Skipping clone..."
else
    git clone https://github.com/dockur/windows.git
fi

# 7. Apply the selected settings and Execute Docker Compose
echo "--> Applying Windows Version: $WIN_VERSION and Disk Size: $DISK_SIZE..."
cd windows

# Create a docker-compose override file to safely inject VERSION and DISK_SIZE variables
cat <<EOF > docker-compose.override.yml
services:
  windows:
    environment:
      VERSION: "${WIN_VERSION}"
      DISK_SIZE: "${DISK_SIZE}"
EOF

echo "--> Starting docker compose in the background..."
sudo docker compose up -d

# Finish
echo "=================================================="
echo "                 PROCESS COMPLETE!                "
echo "=================================================="
echo "Docker has been installed and the container is running."
echo "Windows version '${WIN_VERSION}' with ${DISK_SIZE} disk will automatically setup."
echo ""
echo "Access the installation via Web Browser at:"
echo "http://YOUR_VPS_IP:8006"
echo "=================================================="
